# .env.example

# OpenAI API Key
OPENAI_API_KEY=your-key

# Telegram bot token
TELEGRAM_TOKEN=your_new_bot_token_here

# Redis URL
REDIS_URL=redis://localhost:6379

# Owner ID
OWNER_ID=your-id

# Base URL
BASE_URL=https://your-domain.com

# TAVILY API Key
TAVILY_API_KEY=your-key

# Action Webhook URL
ACTION_WEBHOOK_URL=https://your-webhook.com

# Model Name
MODEL_NAME=gpt-4o

# Application Name
APP_NAME=Nexora

# Creator Name
CREATOR_NAME=Your Name

# Creator Alias
CREATOR_ALIAS=Alias

# Log Level
LOG_LEVEL=INFO

# Environment
ENVIRONMENT=development
